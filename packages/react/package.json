    "react-dom": ">=17"
  },
  "dependencies": {
    "@weldui/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "tsx": "^4.7.0"
  }
