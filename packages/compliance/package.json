{
  "name": "@weldui/compliance",
  "version": "1.0.0",
  "type": "module",
  "description": "WeldUI Compliance Pack — GDPR, SOX, DORA, audit-ready components",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@weldui/core": "workspace:*",
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "vite-plugin-dts": "^3.8.0",
    "typescript": "^5.4.0"
  }
}
