{
  "name": "@weldui/core",
  "version": "0.1.0-beta.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens/base.css": "./dist/tokens/base.css",
    "./tokens/semantic.css": "./dist/tokens/semantic.css",
    "./tokens": "./dist/tokens/base.css",
    "./themes/*": "./dist/themes/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly && mkdir -p dist/tokens && cp src/tokens/*.css dist/tokens/",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "lit": "^3.1.0"
  },
  "devDependencies": {
    "@weldui/build-tools": "workspace:*",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "vite-plugin-dts": "^3.8.0",
    "@open-wc/testing": "^4.0.0",
    "happy-dom": "^12.0.0",
    "typescript": "^5.4.0"
  }
}
